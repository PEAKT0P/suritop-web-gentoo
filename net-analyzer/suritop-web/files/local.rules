# Правило 1: Ловим входящий скан (снаружи внутрь)
alert tcp $EXTERNAL_NET any -> $HOME_NET $SSH_PORTS (msg:"LOCAL Possible SSH scan, setting xbits"; \
  flow:to_server; \
  threshold: type both, track by_src, count 5, seconds 10; \
  xbits:set, ssh_scanner, track ip_src, expire 300; \
  classtype:attempted-recon; sid:1000001; rev:3;)

# Правило 2: ДРОПАЕМ трафик от этого IP
drop tcp $EXTERNAL_NET any -> $HOME_NET $SSH_PORTS (msg:"LOCAL Blocked SSH traffic from known scanner"; \
  xbits:isset, ssh_scanner, track ip_src; \
  classtype:attempted-recon; sid:1000002; rev:3;)


drop http any any -> any any (msg:"LOCAL Test Suricata DROP"; content:"GET /suricata-block-me"; sid:1000099; rev:1;)
